<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/widget_item_background"
    android:padding="6dp"
    android:layout_marginBottom="4dp">

    <!-- Category Color Indicator Line -->
    <FrameLayout
        android:id="@+id/item_color_indicator"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="#3F51B5"
        android:layout_marginRight="8dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/item_event_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:singleLine="true"
            android:text="Sync Meeting"
            android:textColor="#21005D"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/item_event_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="10:00 AM - 11:30 AM"
            android:textColor="#49454F"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Source Provider Badge (G for Google) -->
    <TextView
        android:id="@+id/item_event_source"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:text="G"
        android:textColor="#4285F4"
        android:textSize="10sp"
        android:textStyle="bold"
        android:paddingLeft="4dp"
        android:paddingRight="4dp"
        android:background="@drawable/widget_source_badge" />
</LinearLayout>
